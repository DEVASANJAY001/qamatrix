    "wb = load_workbook(p, data_only=True)\n",
    "print('sheets', wb.sheetnames)\n",
    "ws = wb[wb.sheetnames[0]]\n",
    "for i, row in enumerate(ws.iter_rows(min_row=1, max_row=20, values_only=True)):\n",
    "    print(i, row)"
